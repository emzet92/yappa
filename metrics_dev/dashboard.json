{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["yappa"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "title": "Yappa Planning Poker",
  "version": 2,
  "panels": [

    {
      "type": "stat",
      "title": "Rooms Created",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(yappa_rooms_created_total)" }
      ]
    },

    {
      "type": "stat",
      "title": "Votes Submitted",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(yappa_votes_submitted_total)" }
      ]
    },

    {
      "type": "stat",
      "title": "Participants Joined",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(yappa_participants_joined_total)" }
      ]
    },

    {
      "type": "stat",
      "title": "Health Status",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "yappa_health_status" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "type": "timeseries",
      "title": "HTTP Requests / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total[1m])) by (http_method)",
          "legendFormat": "{{http_method}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Avg HTTP Duration (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_milliseconds_sum[1m]) / rate(http_server_request_duration_milliseconds_count[1m])",
          "legendFormat": "avg"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "p95 HTTP Duration (ms)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }

  ]
}